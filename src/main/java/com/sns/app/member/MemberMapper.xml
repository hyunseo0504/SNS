<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.sns.app.member.MemberMapper">
  
  <select id="search" resultType="MemberDTO" parameterType="String">
    SELECT * FROM "USER"
    WHERE "USER_NICKNAME" LIKE CONCAT('%', #{keyword}, '%')
</select>
  
  <update id="update" parameterType="MemberDTO">
  	UPDATE "USER"
  	<set>
  		<if test="userId != null">"USER_ID"=#{username}</if>
  		<if test="userNickname != null">"USER_NAME"=#{userNickname}</if>
  		<if test="userPw != null">"USER_PW"=#{password}</if>
  		<if test="userEmail != null">"USER_EMAIL"=#{userEmail}</if>
  		<if test="userBirth != null">"USER_BIRTH"=#{userBirth}</if>
  		<if test="userAgr != null">"USER_AGR"=#{userAgr}</if>
  	</set>
  	WHERE "USER_ID"=#{username}
  </update>
  
  <insert id="join" parameterType="MemberDTO" useGeneratedKeys="true" keyProperty="userNo">
  	INSERT INTO "USER"
  	VALUES (
  		default,
  		#{username},
  		#{userNickname},
  		#{password},
  		#{userEmail},
  		#{userBirth},
  		#{userAgr}
  	)
  </insert>
  
  <insert id="addProfile" parameterType="ProfileDTO">
  	INSERT INTO "USER_IMG" ("FILE_NAME", "ORI_NAME", "USER_NO")
  	VALUES (
  		#{fileName},
  		#{oriName},
  		#{userNo}
  	)
  </insert>
  
  <select id="detail" parameterType="MemberDTO" resultMap="detailResult">
  	SELECT u.*,ui.*,r.*
  	FROM "USER" u
  		LEFT JOIN "USER_IMG" ui
  		USING ("USER_NO")
  		LEFT JOIN "USER_ROLE"
  		USING ("USER_NO")
  		LEFT JOIN "ROLE" r
  		USING("ROLE_NO")
  	WHERE u."USER_ID"=#{username}
  </select>
  
  <resultMap type="MemberDTO" id="detailResult">
  	<id column="USER_NO" property="userNo"/>
  	<result column="USER_ID" property="userId"/>
  	<result column="USER_NICKNAME" property="userNickname"/>
  	<result column="USER_PW" property="userPw"/>
  	<result column="USER_EMAIL" property="userEmail"/>
  	<result column="USER_BIRTH" property="userBirth"/>
  	<result column="USER_AGR" property="userAgr"/>
  	<result column="ENABLED" property="enabled"/>
  	<result column="CREDENTIALS_NON_LOCKED" property="credentialsNonLocked"/>
  	<result column="ACCOUNT_NON_LOCKED" property="accountNonLocked"/>
  	<result column="ACCOUNT_NON_EXPIRED" property="accountNonExpired"/>
  	
  	<association property="profileDTO" javaType="profileDTO">
  		<id column="FILE_NO" property="fileNo"/>
  		<result column="FILE_NAME" property="fileName"/>
  		<result column="ORI_NAME" property="oriName"/>
  	</association>
  	<collection property="roles" javaType="java.util.List" ofType="RoleDTO">
  		<id column="ROLE_NO" property="roleNo"/>
  		<result column="ROLE_NAME" property="roleName"/>
  	</collection>
  </resultMap>
  
 <select id="myList" parameterType="MemberDTO" ></select>
  
  
  
  
  
  
  
  </mapper>