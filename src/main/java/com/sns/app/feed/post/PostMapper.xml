<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sns.app.feed.post.PostMapper">
	<select id="getCount" resultType="Long" parameterType="Pager">
		SELECT COUNT("FEED_NO") FROM "POST"
		<!-- <include refid="search_sql"></include> -->
	</select>

	<select id="list" resultMap="detailResult" parameterType="Pager">
		SELECT
		P.*,
		PI."FILE_NO", PI."FILE_NAME", PI."ORI_NAME",
		M."NAME" AS "USER_NAME" FROM "POST" P
		LEFT JOIN "POST_IMG" PI ON P."FEED_NO" = PI."FEED_NO"
		LEFT JOIN "USER" S ON P."USER_NO" = S."USER_NO" 
		ORDER BY P."FEED_DATE" DESC
		LIMIT #{perPage} OFFSET #{startNum}
	</select>

	<select id="detail" parameterType="PostDTO"
		resultMap="detailResult">
		SELECT *
		FROM "POST" P
		LEFT JOIN
		"POST_IMG" PI
		USING ("FEED_NO")
		WHERE "FEED_NO"=#{feedNo}

	</select>
	

	<resultMap type="PostDTO" id="detailResult">
		<id column="FEED_NO" property="feedNo" />
		<result column="FEED_DATE" property="feedDate" />
		<result column="FEED_LOCATION" property="feedLocation" />
		<result column="FEED_CONTENT" property="feedContent" />
		<result column="FEED_THUMB" property="feedThumb" />
		<result column="FEED_REF" property="feedRef" />
		<result column="FEED_STEP" property="feedStep" />
		<result column="FEED_DEPTH" property="feedDepth" />
		<result column="USER_NO" property="userNo" />
		<collection property="list" javaType="java.util.List"
			ofType="PostFileDTO">
			<id column="FILE_NUM" property="fileNum" />
			<result column="FILE_NAME" property="fileName" />
			<result column="ORI_NAME" property="oriName" />
		</collection>

	</resultMap>
	<insert id="create" parameterType="PostDTO"
		useGeneratedKeys="true" keyProperty="feedNo">
		INSERT INTO "POST"
		("FEED_NO","FEED_DATE","FEED_LOCATION","FEED_CONTENT","FEED_THUMB","FEED_REF","FEED_STEP","FEED_DEPTH","USER_NO")
		VALUES (default,
		now(), #{feedLocation}, #{feedContent},
		#{feedThumb},0,0,0,#{userNo})
	</insert>
	<insert id="createFile" parameterType="PostFileDTO">
		INSERT INTO "POST_IMG"
		VALUES (DEFAULT,#{fileName}, #{oriName}, #{feedNo})
	</insert>
	<delete id="delete" parameterType="PostDTO">
		DELETE FROM "POST"
		WHERE
		"FEED_NO"=#{feedNo}
	</delete>
	<delete id="fileDelete" parameterType="FileDTO">
		DELETE FROM "POST_IMG"
		WHERE "FILE_NO"=#{fileNo}
	</delete>

	<delete id="fileDeleteFor" parameterType="java.util.List">
		DELETE FROM "POST_IMG"
		WHERE "FILE_NO" IN
		<foreach item="item" index="index" collection="list" open="("
			separator="," close=")">
			#{item.fileNo}
		</foreach>

	</delete>

	<select id="fileDetail" parameterType="FileDTO"
		resultType="FileDTO">
		SELECT * FROM "POST_IMG"
		WHERE "FILE_NO"=#{fileNo}
	</select>
</mapper>